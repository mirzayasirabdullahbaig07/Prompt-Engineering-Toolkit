<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Agent Architect Studio</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Segoe UI,Tahoma,sans-serif;background:linear-gradient(135deg,#f3f0ff,#ede9fe,#faf5ff);padding:20px;color:#1e1b4b}
.container{max-width:1100px;margin:auto}
.header{text-align:center;padding:30px}
.badge{display:inline-block;background:linear-gradient(90deg,#7c3aed,#a855f7);color:#fff;padding:6px 16px;border-radius:20px;font-size:12px;letter-spacing:2px}
h1{margin:10px 0;font-size:2.3rem;background:linear-gradient(90deg,#5b21b6,#7c3aed,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
p{color:#6b7280}
.card,.panel{background:#fff;border:1.5px solid #c4b5fd;border-radius:18px;padding:24px;box-shadow:0 4px 18px rgba(124,58,237,.1);margin-top:20px}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:15px}
@media(max-width:800px){.grid{grid-template-columns:1fr}}
label{font-size:12px;font-weight:700;color:#7c3aed}
input,select{width:100%;padding:10px;margin-top:8px;border:1px solid #ddd6fe;border-radius:10px;background:#faf5ff}
button{margin-top:18px;padding:12px 18px;border:none;border-radius:10px;background:linear-gradient(135deg,#7c3aed,#5b21b6);color:#fff;font-weight:700;cursor:pointer}
.name{font-size:1.5rem;color:#5b21b6;font-weight:900}
.role{color:#6d28d9;margin:6px 0 14px}
.tags{display:flex;flex-wrap:wrap;gap:8px}
.tag{background:#ede9fe;border:1px solid #c4b5fd;padding:6px 12px;border-radius:20px;font-size:12px}
.box{margin-top:12px;padding:12px;background:#faf5ff;border-left:5px solid #7c3aed;border-radius:8px}
.footer{text-align:center;margin-top:20px;color:#888}
.footer span{color:#7c3aed;font-weight:bold}
</style>
</head>
<body>
<div class="container">
<div class="header">
<div class="badge">AI ENGINEERING SUITE</div>
<h1>AI Agent Architect Studio</h1>
<p>Design intelligent AI agents for automation, business and productivity.</p>
</div>

<div class="card">
<div class="grid">
<div><label>AGENT NAME</label><input id="agent" placeholder="SalesGPT"></div>
<div><label>BUSINESS DOMAIN</label><input id="domain" placeholder="Healthcare"></div>
<div><label>PRIMARY GOAL</label><input id="goal" placeholder="Automate customer support"></div>
<div><label>PERSONALITY</label>
<select id="personality">
<option>Professional</option><option>Friendly</option><option>Analytical</option><option>Creative</option>
</select></div>
</div>
<button onclick="build()">Generate AI Agent</button>
</div>

<div class="panel" id="panel" style="display:none">
<div class="name" id="title"></div>
<div class="role" id="subtitle"></div>
<div class="tags" id="tags"></div>
<div class="box" id="mission"></div>
<div class="box" id="workflow"></div>
<div class="box" id="stack"></div>
</div>

<div class="footer">Developed by <span>Hamna Munir</span> | <span>Mirza Yasir Abdullah Baig</span></div>
</div>
<script>
function build(){
let a=agent.value,d=domain.value,g=goal.value,p=personality.value;
if(!a||!d||!g){alert("Fill all fields");return;}
panel.style.display="block";
title.textContent=a+" AI Agent";
subtitle.textContent=d+" Automation Specialist";
let arr=["Reasoning","Planning","Memory","Automation","API Integration","Decision Making"];
tags.innerHTML=arr.map(x=>`<div class="tag">${x}</div>`).join("");
mission.innerHTML="<b>Mission:</b> Help "+d+" organizations by "+g+" using a "+p+" communication style.";
workflow.innerHTML="<b>Workflow:</b> Receive Request → Analyze Intent → Plan Action → Execute Task → Validate Output → Respond.";
stack.innerHTML="<b>Suggested Stack:</b> LLM, Vector Database, RAG, REST APIs, Dashboard, Cloud Deployment.";
}
</script>
</body>
</html>
